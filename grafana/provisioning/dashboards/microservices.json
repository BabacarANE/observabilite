{
  "title": "Observability TP — Microservices",
  "uid": "observability-tp",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total[1m])) by (service) / sum(rate(http_requests_total[1m])) by (service) * 100",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Average Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum[1m])) by (service) / sum(rate(http_request_duration_seconds_count[1m])) by (service) * 1000",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, service)) * 1000",
          "legendFormat": "p95 {{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Requests by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (service, route)",
          "legendFormat": "{{service}} — {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(http_errors_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Services UP",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "count(up{job=~\"api-gateway|service-orders|service-users\"} == 1)",
          "refId": "A"
        }
      ]
    }
  ]
}
